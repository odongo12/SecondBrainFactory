# Copy this file to .env (same folder) and fill in your real key.
# .env is gitignored — never commit real keys.
ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# Optional — defaults to claude-sonnet-5 if unset.
NAVIGATOR_MODEL=claude-sonnet-5

# Required before exposing this backend publicly (e.g. via cloudflared) —
# without it, /run and /chat are unauthenticated and anyone with the public
# URL could hit them and burn your Anthropic API key. A random one was
# generated for this setup: paste the SAME value into the GPT's Actions
# authentication config (API Key, Custom header "X-Navigator-Secret") in
# the ChatGPT builder so only the real GPT (and your local app) can call it.
NAVIGATOR_SHARED_SECRET=G1k79JcLM8pbfEqdXVIxGyvS8JZ7kd11V8CRL5zFdLo
